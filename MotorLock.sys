	<Mapping From="UserSimulator.TrigerDelayTrigger_3" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.TriggerMotor1AndMotor2" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.TrigerDelayTrigger_1" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.TriggerMotor2StopMotor1" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.TrigerDelayTrigger" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.E_SWITCH_2" To="UserSimulator.EMB_RES"/>
	<Mapping From="UserSimulator.E_CTU_2" To="UserSimulator.EMB_RES"/>
	<Mapping From="MotorsController.TurnMotor2OnOff" To="Controller.EMB_RES"/>
	<Mapping From="MotorsController.TurnMotor1OnOff" To="Controller.EMB_RES"/>
